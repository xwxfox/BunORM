  "tags": [
    "orm",
    "typescript",
    "typescript-orm",
    "sqlite",
    "bun:sqlite",
    "bun",
    "bun.js",
    "bun.sh"
  ],
  "author": "xwxfox",
  "repository": {
    "type": "git",
    "url": "https://github.com/xwxfox/foxdb.git"
  },
