  "files": [
    "lib/**/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typedoc": "^0.28.19",
    "typedoc-plugin-coverage": "^4.0.3",
    "typedoc-plugin-extras": "^4.0.1",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5",
